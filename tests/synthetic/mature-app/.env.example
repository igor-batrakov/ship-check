# Copy to .env.local and fill in real values. Never commit the filled-in file.

# Public site URL — embedded in the client bundle, safe to expose.
NEXT_PUBLIC_SITE_URL=https://app.example.com

# Origin allowed to call the API (used for CORS on API responses). Server-side only.
APP_ORIGIN=https://app.example.com

# Supabase project. SUPABASE_ANON_KEY is meant for clients and works together
# with Row Level Security. SUPABASE_SERVICE_ROLE_KEY bypasses RLS — server only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# OpenAI — paid API, server-side only.
OPENAI_API_KEY=replace-with-your-openai-key
